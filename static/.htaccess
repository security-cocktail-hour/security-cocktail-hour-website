# Security Cocktail Hour - Apache Configuration for GoDaddy cPanel
# This file enforces trailing slashes for SEO consistency

# Custom 404 Error Page
ErrorDocument 404 /404.html

# Enable mod_rewrite for URL manipulation
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Force HTTPS (if not already on HTTPS)
    RewriteCond %{HTTPS} off
    RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [L,R=301]

    # ==================================================================
    # 301 Redirects for old URLs (from previous site)
    # These MUST come before the trailing slash rule so they fire first.
    # Updated: March 11, 2026
    # ==================================================================

    # Old transcript pages → New episode pages
    RewriteRule ^transcript-ep-59/?$ /episodes/episode-59-wifi-pineapple-unboxing-the-hacker-device-from-tv-shows/ [L,R=301]
    RewriteRule ^transcript-ep-60/?$ /episodes/episode-60-crypto-kidnappings-lost-keys-and-million-dollar-bug-bounties/ [L,R=301]
    RewriteRule ^transcript-ep-61/?$ /episodes/episode-61-ai-attacks-need-ai-defense-ransomwares-new-danger-and-how-a-top-cyber-expert-is-/ [L,R=301]
    RewriteRule ^transcript-ep-21/?$ /episodes/episode-21-medical-devices-halloween-and-whiskey-with-gabrielle-hempel/ [L,R=301]
    RewriteRule ^transcript-ep-53/?$ /episodes/episode-53-the-new-rules-of-cyber-incident-response-new-attacks-new-response/ [L,R=301]
    RewriteRule ^transcript-hak5-unboxing/?$ /episodes/ [L,R=301]

    # Old episode list pages → New episodes page
    RewriteRule ^episodes-1-10/?$ /episodes/ [L,R=301]
    RewriteRule ^episodes-11-20/?$ /episodes/ [L,R=301]
    RewriteRule ^episodes-21-30/?$ /episodes/ [L,R=301]
    RewriteRule ^episodes-31-40(-1)?/?$ /episodes/ [L,R=301]
    RewriteRule ^episodes-41-50-1/?$ /episodes/ [L,R=301]
    RewriteRule ^episodes-51-60(-1)?/?$ /episodes/ [L,R=301]
    RewriteRule ^episodes-61-70/?$ /episodes/ [L,R=301]

    # Old info pages → New about page
    RewriteRule ^consulting/?$ /about/ [L,R=301]
    RewriteRule ^bios/?$ /about/ [L,R=301]
    RewriteRule ^guest-appearances/?$ /about/ [L,R=301]
    RewriteRule ^co-host-appearances/?$ /about/ [L,R=301]

    # Old support page → Partnership page
    RewriteRule ^support-us/?$ /partnership/ [L,R=301]

    # Old misc pages → Homepage
    RewriteRule ^afterparties/?$ / [L,R=301]
    RewriteRule ^gallery/?$ / [L,R=301]

    # Old store/merchandise pages → Homepage (store is currently hidden)
    RewriteRule ^store/?$ / [L,R=301]
    RewriteRule ^store-2/?$ / [L,R=301]
    RewriteRule ^store-\|-(pens|clothing).*$ / [L,R=301]
    RewriteRule ^merchandise1?/?$ / [L,R=301]

    # ==================================================================

    # Force trailing slashes for directories (not files)
    # This prevents duplicate content issues with /page and /page/

    # Skip if already has trailing slash
    RewriteCond %{REQUEST_URI} !(.*)/$

    # Skip if it's a file (has an extension like .css, .js, .jpg)
    RewriteCond %{REQUEST_FILENAME} !-f

    # Skip if path contains a dot (likely a file)
    RewriteCond %{REQUEST_URI} !\.[^./]+$

    # Add trailing slash with 301 permanent redirect
    RewriteRule ^(.*)$ https://securitycocktailhour.com/$1/ [L,R=301]
</IfModule>

# Security Headers
<IfModule mod_headers.c>
    # Prevent clickjacking
    Header always set X-Frame-Options "DENY"

    # XSS Protection
    Header always set X-XSS-Protection "1; mode=block"

    # Prevent MIME type sniffing
    Header always set X-Content-Type-Options "nosniff"

    # Referrer Policy
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# Caching for static assets
<IfModule mod_expires.c>
    ExpiresActive On

    # Images
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"

    # CSS and JavaScript
    ExpiresByType text/css "access plus 1 year"
    ExpiresByType application/javascript "access plus 1 year"
    ExpiresByType application/x-javascript "access plus 1 year"

    # Fonts
    ExpiresByType font/woff "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType application/font-woff "access plus 1 year"
    ExpiresByType application/font-woff2 "access plus 1 year"
</IfModule>

# Gzip compression
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css
    AddOutputFilterByType DEFLATE application/xml application/xhtml+xml application/rss+xml
    AddOutputFilterByType DEFLATE application/javascript application/x-javascript
</IfModule>
